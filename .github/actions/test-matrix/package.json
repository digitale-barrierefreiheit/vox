{
  "name": "vox-test-matrix-action",
  "version": "1.0.0",
  "private": true,
  "description": "Post/update one PR comment with a live test x job results matrix.",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --license licenses.txt",
    "test": "node --import tsx --test src/*.test.ts",
    "check": "tsc --noEmit && npm test && npm run build"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "fast-xml-parser": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vercel/ncc": "^0.38.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
