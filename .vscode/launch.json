{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug core_version_test (Windows)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/x64-msvc/tests/core/Debug/core_version_test.exe",
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "preLaunchTask": "CMake: build (x64-msvc Debug)"
    },
    {
      "name": "Debug core_version_test (Linux/Clang)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/linux-clang/tests/core/Debug/core_version_test",
      "args": [],
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
