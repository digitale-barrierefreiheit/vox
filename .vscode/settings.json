{
  // Editor — mirror .editorconfig so contributors without the EditorConfig
  // extension still get 2-space indent and trimmed whitespace.
  "editor.insertSpaces": true,
  "editor.tabSize": 2,
  "editor.detectIndentation": false,
  "editor.rulers": [100],
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.eol": "\n",

  // C/C++ — format with the repo .clang-format on save.
  "editor.formatOnSave": true,
  "[cpp]": {
    "editor.defaultFormatter": "ms-vscode.cpptools"
  },
  "[c]": {
    "editor.defaultFormatter": "ms-vscode.cpptools"
  },
  "C_Cpp.formatting": "clangFormat",
  "C_Cpp.clang_format_style": "file",
  "C_Cpp.codeAnalysis.clangTidy.enabled": true,
  "C_Cpp.codeAnalysis.clangTidy.useBuildPath": true,
  "C_Cpp.default.cppStandard": "c++23",
  "C_Cpp.intelliSenseEngine": "default",

  // CMake Tools — drive everything through CMakePresets.json so VSCode, Visual
  // Studio, and the CLI agree. Pick a configure preset via the status bar.
  "cmake.useCMakePresets": "always",
  "cmake.options.statusBarVisibility": "visible",
  "cmake.copyCompileCommands": "${workspaceFolder}/build/compile_commands.json",

  // IntelliSense reads the generated compile database.
  "C_Cpp.default.compileCommands": "${workspaceFolder}/build/compile_commands.json",

  // Keep the tree focused on sources.
  "files.associations": {
    "*.hpp.in": "cpp"
  },
  "search.exclude": {
    "**/build": true,
    "**/vcpkg_installed": true
  }
}
