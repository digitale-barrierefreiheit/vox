{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "windows-base",
      "hidden": true,
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-static"
      }
    },
    {
      "name": "x64-msvc",
      "displayName": "Windows x64 (MSVC, static CRT)",
      "description": "Shipping toolchain. cl.exe, /MT, x64 (ADR-08/ADR-14).",
      "inherits": "windows-base",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static"
      }
    },
    {
      "name": "x86-msvc",
      "displayName": "Windows x86 (MSVC, static CRT)",
      "description": "32-bit helper bitness (architecture §8.3.1, R12).",
      "inherits": "windows-base",
      "architecture": {
        "value": "x86",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl",
        "VCPKG_TARGET_TRIPLET": "x86-windows-static"
      }
    },
    {
      "name": "x64-clang-cl",
      "displayName": "Windows x64 (clang-cl, static CRT)",
      "description": "Alternate Microsoft-ABI compiler measured against MSVC (ADR-14).",
      "inherits": "windows-base",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static"
      }
    },
    {
      "name": "linux-clang",
      "displayName": "Linux x64 (Clang)",
      "description": "Portable-core build used for the sanitizer matrix (ADR-12/ADR-14).",
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "VCPKG_TARGET_TRIPLET": "x64-linux"
      }
    },
    {
      "name": "linux-clang-asan",
      "displayName": "Linux x64 (Clang, ASan+UBSan)",
      "inherits": "linux-clang",
      "cacheVariables": {
        "VOX_SANITIZER": "address+undefined"
      }
    },
    {
      "name": "linux-clang-tsan",
      "displayName": "Linux x64 (Clang, TSan)",
      "inherits": "linux-clang",
      "cacheVariables": {
        "VOX_SANITIZER": "thread"
      }
    },
    {
      "name": "macos-clang",
      "displayName": "macOS (Clang)",
      "description": "Local macOS build for clang-tidy; no shipping target yet (macOS is a later milestone).",
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    }
  ],
  "buildPresets": [
    { "name": "x64-msvc-debug",        "configurePreset": "x64-msvc",        "configuration": "Debug" },
    { "name": "x64-msvc-release",      "configurePreset": "x64-msvc",        "configuration": "Release" },
    { "name": "x86-msvc-debug",        "configurePreset": "x86-msvc",        "configuration": "Debug" },
    { "name": "x86-msvc-release",      "configurePreset": "x86-msvc",        "configuration": "Release" },
    { "name": "x64-clang-cl-release",  "configurePreset": "x64-clang-cl",    "configuration": "Release" },
    { "name": "linux-clang-debug",     "configurePreset": "linux-clang",     "configuration": "Debug" },
    { "name": "linux-clang-asan",      "configurePreset": "linux-clang-asan","configuration": "Debug" },
    { "name": "linux-clang-tsan",      "configurePreset": "linux-clang-tsan","configuration": "Debug" },
    { "name": "macos-clang-debug",     "configurePreset": "macos-clang",     "configuration": "Debug" }
  ],
  "testPresets": [
    {
      "name": "common",
      "hidden": true,
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false }
    },
    { "name": "x64-msvc-debug",   "inherits": "common", "configurePreset": "x64-msvc",         "configuration": "Debug" },
    { "name": "x64-msvc-release", "inherits": "common", "configurePreset": "x64-msvc",         "configuration": "Release" },
    { "name": "x86-msvc-debug",   "inherits": "common", "configurePreset": "x86-msvc",         "configuration": "Debug" },
    { "name": "x86-msvc-release", "inherits": "common", "configurePreset": "x86-msvc",         "configuration": "Release" },
    { "name": "linux-clang-debug","inherits": "common", "configurePreset": "linux-clang",      "configuration": "Debug" },
    { "name": "linux-clang-asan", "inherits": "common", "configurePreset": "linux-clang-asan", "configuration": "Debug" },
    { "name": "linux-clang-tsan", "inherits": "common", "configurePreset": "linux-clang-tsan", "configuration": "Debug" },
    { "name": "macos-clang-debug","inherits": "common", "configurePreset": "macos-clang",      "configuration": "Debug" }
  ]
}
