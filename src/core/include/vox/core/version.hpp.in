/// @file
/// @brief Compile-time and run-time build metadata for Vox.
///
/// This header is generated by CMake from `version.hpp.in`; the `@...@`
/// placeholders are substituted with values from the top-level `project()`
/// call. Include `<vox/core/version.hpp>` (the generated copy), never the
/// `.in` template.
#ifndef VOX_CORE_VERSION_HPP
#define VOX_CORE_VERSION_HPP

#include <cstdint>
#include <string_view>

/// Root namespace for all first-party Vox code.
namespace vox::core {

/// Major version component, fixed at configure time (incompatible API changes).
inline constexpr std::uint32_t VersionMajor = @PROJECT_VERSION_MAJOR@;
/// Minor version component, fixed at configure time (compatible additions).
inline constexpr std::uint32_t VersionMinor = @PROJECT_VERSION_MINOR@;
/// Patch version component, fixed at configure time (compatible fixes).
inline constexpr std::uint32_t VersionPatch = @PROJECT_VERSION_PATCH@;
/// Dotted version string, e.g. "0.0.1".
inline constexpr std::string_view VersionString = "@PROJECT_VERSION@";

/// Immutable description of the build's semantic version.
struct VersionInfo {
  std::uint32_t major;     ///< Incompatible API changes.
  std::uint32_t minor;     ///< Backwards-compatible additions.
  std::uint32_t patch;     ///< Backwards-compatible fixes.
  std::string_view text;   ///< Human-readable dotted string.
};

/// @brief Returns the semantic version this binary was built with.
/// @return A populated VersionInfo; never throws and allocates nothing.
[[nodiscard]] VersionInfo version() noexcept;

}  // namespace vox::core

#endif  // VOX_CORE_VERSION_HPP
