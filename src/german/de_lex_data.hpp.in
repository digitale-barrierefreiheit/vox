/// @file
/// @brief The canonical German lexicon table, embedded at configure time.
///
/// Generated by CMake from `data/lexicon/de.lex` (see src/german/CMakeLists.txt)
/// so the pure library and its tests need no filesystem access. Parse it with
/// `vox::german::Lexicon::parse(DefaultGermanLexiconData)`. Never include the
/// `.in` template — include the generated `<vox/german/de_lex_data.hpp>`.
#ifndef VOX_GERMAN_DE_LEX_DATA_HPP
#define VOX_GERMAN_DE_LEX_DATA_HPP

#include <string_view>

namespace vox::german {

/// The contents of `data/lexicon/de.lex` as shipped (UTF-8).
inline constexpr std::string_view DefaultGermanLexiconData =
    R"VOXLEX(@VOX_DE_LEX_CONTENT@)VOXLEX";

}  // namespace vox::german

#endif  // VOX_GERMAN_DE_LEX_DATA_HPP
